algoritmo "Ingresso"
// Autor : Maria Eduarda Vilela e Riquelme
// Data : 14/04/2026

var
// Seção de Declarações
idade : real

inicio
// Seção de Comandos 
   escreva ("Informe sua idade: ")
   leia (idade)
   
   se (idade < 5) ou (idade >= 65) entao
      escreval ("Sua entrada será gratuita")
   senao
   escreval ("Sua entrada será paga")
fimse
fimalgoritmo
